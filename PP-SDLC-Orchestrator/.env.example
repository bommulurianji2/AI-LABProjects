# Copy to .env and adjust as needed. Never commit the real .env file.

# SQLAlchemy database URL. Defaults to a local SQLite file under backend/ if unset.
# PPSDLC_DATABASE_URL=sqlite:///./backend/pp_sdlc.db

# Overrides for the agent/template/generated-artefact directories (defaults are
# relative to the repo root and normally don't need to be set).
# PPSDLC_AGENT_SKILLS_DIR=./03_Agent_Skills
# PPSDLC_TEMPLATES_DIR=./04_Templates
# PPSDLC_GENERATED_ARTEFACTS_DIR=./05_Generated_Artefacts

# --- Deferred to later sessions (not yet read by any code) ---
# Microsoft Entra ID / Graph — required once M365 adapters move off mocks.
# PPSDLC_ENTRA_TENANT_ID=
# PPSDLC_ENTRA_CLIENT_ID=
# PPSDLC_ENTRA_CLIENT_SECRET=

# Azure OpenAI / Foundry — required once an agent's manifest sets runtime: llm.
# PPSDLC_AZURE_OPENAI_ENDPOINT=
# PPSDLC_AZURE_OPENAI_API_KEY=

# Azure AI Document Intelligence / Content Safety / Language PII.
# PPSDLC_AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
# PPSDLC_AZURE_CONTENT_SAFETY_ENDPOINT=
# PPSDLC_AZURE_LANGUAGE_ENDPOINT=
